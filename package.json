{
  "name": "@knox.zhang/nsv",
  "version": "1.0.0",
  "description": "CLI server scaffold",
  "type": "module",
  "bin": {
    "nsv": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "nitro dev",
    "build": "nitro build",
    "postbuild": "node script/init.mjs",
    "preview": "node .output/server/index.mjs",
    "typecheck": "tsc --noEmit",
    "cli:build": "tsc -p tsconfig.cli.json && node script/build-templates.mjs",
    "release": "pnpm cli:build && npm publish --access=public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ejs": "^3.1.10",
    "fs-extra": "^11.3.3",
    "inquirer": "^9.2.23",
    "mysql2": "^3.16.0"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^25.0.3",
    "nitro": "3.0.1-alpha.1",
    "vite": "^7.3.0"
  }
}
